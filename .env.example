# ─────────────────────────────────────────────────────────────
# Contact Form → Telegram (direct, no Supabase required)
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.
#
# VITE_TELEGRAM_BOT_TOKEN – get from @BotFather on Telegram
# VITE_TELEGRAM_CHAT_ID   – target group/chat ID (optional;
#                           defaults to the dagrand group)
# ─────────────────────────────────────────────────────────────
VITE_TELEGRAM_BOT_TOKEN=your_bot_token_here
# VITE_TELEGRAM_CHAT_ID=-1003986946717

# ─────────────────────────────────────────────────────────────
# Supabase (only needed for admin features; contact form can
# work without it when VITE_TELEGRAM_BOT_TOKEN is set above)
# ─────────────────────────────────────────────────────────────
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
